<Window x:Class="catStore.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:catStore"
        mc:Ignorable="d"
        Title="Главная" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="65*"/>
            <RowDefinition Height="377*"/>
        </Grid.RowDefinitions>
        <Rectangle Fill="LightGreen"></Rectangle>
        <Image Margin="10 5 0 5" Source="/Assets/img/logo.webp"  HorizontalAlignment="Left" VerticalAlignment="Center"></Image>
        <TextBlock FontSize="16" FontWeight="Medium" x:Name="titleTextBlock" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10 0 10 0">Главная</TextBlock>
        <Button x:Name="buttonBack" Click="buttonBack_Click" HorizontalAlignment="Right" Margin="0 0 10 0" Padding="15 5" Background="Yellow" VerticalAlignment="Center">Назад</Button>

        <Frame x:Name="mainFrame" Grid.Row="1"  NavigationUIVisibility="Hidden" Navigated="mainFrame_Navigated"></Frame>
    </Grid>
</Window>
