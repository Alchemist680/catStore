<Page x:Class="catStore.Assets.Views.Services"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:catStore.Assets.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Каталог">

    <Grid Background="#fff">
        <Grid.RowDefinitions>
            <RowDefinition Height="10*"></RowDefinition>
            <RowDefinition Height="80*"/>
            <RowDefinition Height="10*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <ComboBox Margin="0 0 10 0" Name="ComboBoxPrice" SelectionChanged="ComboBoxPrice_SelectionChanged" Width="150" VerticalAlignment="Center" Padding="5">
                <ComboBoxItem Name="up">По возврастанию цены</ComboBoxItem>
                <ComboBoxItem Name="down">По убыванию цены</ComboBoxItem>
            </ComboBox>
            <ComboBox Margin="0 0 10 0" Name="ComboBoxCategory" SelectionChanged="ComboBoxCategory_SelectionChanged" Width="150" VerticalAlignment="Center" Padding="5">
                
            </ComboBox>
            <TextBox VerticalAlignment="Center" Width="120" x:Name="SearchTextBox" Padding="10 5"></TextBox>
            <Button VerticalAlignment="Center" Background="Green" Foreground="#fff" Padding="10 5" Name="SearchButton" Click="SearchButton_Click">Искать</Button>
        </StackPanel>
        <ListView Grid.Row="1" Name="ListViewCalalog">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"></WrapPanel>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border CornerRadius="5" Padding="5" Background="LightBlue">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"></ColumnDefinition>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Image Source="{Binding ImagePathValue}" Margin="0 0 5 0"></Image>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Medium" Margin="0 0 0 5"></TextBlock>
                                <TextBlock Text="{Binding Description}" FontSize="12" Margin="0 0 0 5"></TextBlock>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding OldPrice}" FontSize="12" Margin="0 0 5 5" TextDecorations="Strikethrough"></TextBlock>
                                    <TextBlock Text="{Binding NewPrice}" FontSize="12" Margin="0 0 0 5" FontWeight="Medium"></TextBlock>
                                </StackPanel>
                                <TextBlock Text="{Binding Discount}" FontSize="12" Margin="0 0 0 5"></TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        
    </Grid>
</Page>
