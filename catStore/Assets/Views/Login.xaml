<Page x:Class="catStore.Assets.Views.Login"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:catStore.Assets.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Авторизация">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Margin="0 0 0 7">Введите логин</TextBlock>
            <TextBox Margin="0 0 0 7" Width="170" Padding="0 5" Name="loginTextBox"></TextBox>
            <TextBlock Margin="0 0 0 7">Введите пароль</TextBlock>
            <PasswordBox Margin="0 0 0 7" Width="170" Padding="0 5" Name="passwordTextBox"></PasswordBox>
            <Button Width="170" Height="30" Background="Green" Name="LoginButton" Click="LoginButton_Click">Войти</Button>
        </StackPanel>
    </Grid>
</Page>
